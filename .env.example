# Copy to .env — Vite exposes variables prefixed with VITE_.

# --- API base (CORS) ---
# Option A — No CORS in local dev: leave empty. The app calls /v1/... on the same
# origin as the Vite dev server; vite.config.ts proxies /v1 to your API (see VITE_DEV_API_PROXY).
VITE_API_BASE_URL=

# Option B — Call the API directly. The server at localhost:3000 must allow your
# Vite port in CORS (e.g. Access-Control-Allow-Origin: http://localhost:8080).
# VITE_API_BASE_URL=http://localhost:3000

# Where to proxy /v1 when VITE_API_BASE_URL is empty (Vite dev + preview only).
# VITE_DEV_API_PROXY=http://localhost:3000

# Optional path overrides
# VITE_USER_PRODUCT_PATH=/v1/user/product
# VITE_USER_PRODUCT_PAGINATED_PATH=/v1/user/product/paginated
